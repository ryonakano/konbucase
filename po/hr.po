#: data/konbucase.desktop.in.in:3
msgid "@APP_NAME@"
msgstr "@APP_NAME@"

#: data/konbucase.desktop.in.in:4
msgid "Case Converting App"
msgstr "Aplikacija za pretvaranje veličine slova"

#: data/konbucase.desktop.in.in:5 data/konbucase.metainfo.xml.in.in:11
msgid "Convert case in your text"
msgstr "Pretvori veličinu slova u tekstu"

#: data/konbucase.desktop.in.in:11
msgid "Text;"
msgstr "Text;"

#: data/konbucase.metainfo.xml.in.in:13
msgid "A small text tool app that allows you convert case in your text."
msgstr ""
"Mala tekstualna aplikacija koja omogućuje pretvaranje veličine slova u "
"tekstu."

#: data/konbucase.metainfo.xml.in.in:16
msgid "Features include:"
msgstr "Funkcije ukljućuju:"

#: data/konbucase.metainfo.xml.in.in:18
msgid ""
"Click \"Copy to Clipboard\" button to copy the all texts in the text view "
"without selecting them"
msgstr ""
"Klikni na gumb „Kopiraj u međuspremnik” i kopiraj sve tekstove u tekstualnom "
"prikazu bez potrebe za odabiranjem"

#: data/konbucase.metainfo.xml.in.in:19
msgid "Click \"Quick Swap\" button to swap case and text of input and output"
msgstr ""
"Klikni na gumb „Brza zamjena” za mijenjanje veličina slova i teksta unosa i "
"rezultata"

#: data/konbucase.metainfo.xml.in.in:20
msgid ""
"Convert your text between camelCase, PascalCase, Sentence case, snake_case, "
"kebab-case, and space-separated"
msgstr ""
"Odaberi način mijenjanja velične slova teksta: camelCase, PascalCase, "
"Sentencecase, snake_case, kebab-case i space-separated"

#: data/konbucase.metainfo.xml.in.in:26
msgid "App window in the light mode"
msgstr "Prozor aplikacije u svijetlom modusu"

#: data/konbucase.metainfo.xml.in.in:31
msgid "App window in the dark mode"
msgstr "Prozor aplikacije u tamnom modusu"

#: data/ui/help-overlay.blp:10
msgctxt "shortcut window"
msgid "General"
msgstr "Opće"

#: data/ui/help-overlay.blp:14
msgctxt "shortcut window"
